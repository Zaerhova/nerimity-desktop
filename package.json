{
  "name": "nerimity-desktop",
  "version": "2.2.0",
  "description": "A modern and sleek chat app.",
  "main": "src/main.js",
  "type": "module",
  "repository": "https://github.com/Nerimity/nerimity-desktop",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch * --exec electron .",
    "publish-win": "electron-builder --win -p always",
    "publish-mac": "electron-builder --mac -p always",
    "app:dir": "electron-builder --dir",
    "app:dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "SupertigerDev <supertigerrrrr@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "nerimity.geekuane.quest",
    "productName": "Nerimity",
    "npmRebuild": true,
    "buildDependenciesFromSource": true,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon-512.png",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Network",
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Zaerhova",
      "repo": "Zaerhova/nerimity-desktop" 
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!.github/**/*"
    ]
  },
  "dependencies": {
    "@nerimity/active-window-listener": "^2.0.6",
    "application-loopback": "^1.2.7",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "node-abi": "^3.78.0",
    "portfinder": "^1.0.38",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.20.0"
  }
}
